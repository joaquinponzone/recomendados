# Base de datos (Turso / LibSQL). Misma convención que matchday: URL obligatoria en runtime.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Auth
ADMIN_EMAIL=
ADMIN_PASSWORD=
SESSION_SECRET=
APP_URL=http://localhost:3000

# Email (recuperación de contraseña)
RESEND_API_KEY=
RESEND_FROM_DOMAIN=

# Vercel Blob (subida de imágenes de recomendaciones). Token del dashboard del store.
BLOB_READ_WRITE_TOKEN=
# Opcional: forzar blobs privados + URL proxy (/api/recommendation-blob). Si no está, se intenta
# access public y, si el store es solo privado, se reintenta automáticamente con private.
# BLOB_ACCESS=private

# Drizzle (como en matchday): `bun run db:push` para aplicar schema; `bun run db:generate` si generás migraciones SQL; `bun run db:studio` para inspeccionar.
# Luego: `bun run db:seed` si corres seed.
